*.dump
*.sql.bak

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Node / npm ────────────────────────────────────────────────────────────────
# obsidian-plugin/ is bundled via esbuild — node_modules is local-only.
# package-lock.json IS committed (required by `npm ci` in .github/workflows/release.yml).
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build artifacts in plugin dir (release workflow regenerates) ──────────────
obsidian-plugin/SHA256SUMS

*.exe
*.exe~
*.dll
*.so
*.dylib
sync/auth-server/obsidian-auth
sync/auth-server/obsidian-auth.exe

# Go build cache / test artifacts
*.test
*.out
vendor/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# ── Neon / DB ─────────────────────────────────────────────────────────────────
